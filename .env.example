# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME="Brionic Reports"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://reports.brionicsecurity.com
# Random 32+ char secret. Used to salt the daily visitor hash.
#   php -r "echo bin2hex(random_bytes(24)), PHP_EOL;"
APP_KEY=
APP_TIMEZONE=UTC

# ── Operator sign-in (single user) ───────────────────────────────────────────
ADMIN_EMAIL=you@example.com
# Generate:  php -r "echo password_hash('your-strong-password', PASSWORD_DEFAULT), PHP_EOL;"
ADMIN_PASSWORD_HASH=

# ── Database ─────────────────────────────────────────────────────────────────
# Local dev: sqlite. Production: mysql.
DB_DRIVER=sqlite
DB_SQLITE_PATH=storage/database.sqlite

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=brionic_reports
DB_USERNAME=
DB_PASSWORD=

# ── Geolocation (free, no key) ───────────────────────────────────────────────
GEO_ENABLED=true
GEO_ENDPOINT=https://ipwho.is/

# ── Mail (weekly client reports) ─────────────────────────────────────────────
# driver: log (dev) or smtp (production).
MAIL_DRIVER=log
MAIL_FROM_ADDRESS=reports@brionicsecurity.com
MAIL_FROM_NAME="Brionic Reports"
MAIL_SUPPORT_ADDRESS=support@brionicsecurity.com
SMTP_HOST=
# Use 2525 if your host blocks 587/465/25 (e.g. DigitalOcean blocks outbound SMTP by default)
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_ENCRYPTION=tls

# ── Search-engine integration (Google Search Console + Bing) ─────────────────
# All optional — the feature stays dormant until set. See the Integrations page.
# Google Cloud OAuth client (enable Search Console API + Site Verification API).
# Authorized redirect URI: <APP_URL>/integrations/google/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Bing Webmaster Tools → Settings → API access → API Key.
BING_WEBMASTER_API_KEY=
# IndexNow key (32 hex): php -r "echo bin2hex(random_bytes(16));"
INDEXNOW_KEY=
# Optional: Cloudflare API token (Zone:Read + DNS:Edit) for auto DNS verification.
CLOUDFLARE_API_TOKEN=

