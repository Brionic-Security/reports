{
    "name": "brionic-security/reports",
    "description": "Brionic Reports — open-source, privacy-first, multi-site web analytics with client report emails.",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        },
        "files": [
            "app/helpers.php"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "scripts": {
        "migrate": "php scripts/migrate.php",
        "serve": "php -S 127.0.0.1:8790 -t public public/index.php"
    }
}
